{
  "name": "claude-code-desktop",
  "version": "0.2.0",
  "description": "Fan-made Electron desktop UI for the Claude Code CLI — live context panel, permission modes, JSX preview, workspace awareness",
  "homepage": "https://github.com/hlsitechio/Claude-Code-Mods",
  "repository": {
    "type": "git",
    "url": "https://github.com/hlsitechio/Claude-Code-Mods.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "electron",
    "desktop",
    "ai",
    "coding-assistant"
  ],
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port 5182",
    "build": "vite build",
    "preview": "vite preview --port 5183",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:5182 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:dir": "npm run build && electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "dev.hlsitechio.claude-code-desktop",
    "productName": "Claude Code",
    "copyright": "Fan-made UI redesign — not affiliated with Anthropic",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ClaudeCode-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Code",
      "installerHeaderIcon": "",
      "deleteAppDataOnUninstall": false
    },
    "publish": null
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "dockview-core": "^5.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
