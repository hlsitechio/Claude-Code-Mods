# Dependencies
node_modules/

# Build output
dist/
release/

# Claude CLI internal state
.claude/

# ── Personal / instance-specific data ─────────────────────────────────────────
# Chat session history (personal conversations)
sessions/*.json

# User memory files (personal profile, preferences)
memory/*.md

# Saved code block artifacts (personal exports)
codeblocks/*/
codeblocks/*.html
codeblocks/.counter.json

# Live notes (personal scratchpad)
notes/*.md

# Personal agent configs that reference private infrastructure
agents/crowbyte-ops.json
agents/Crowbyte_Ops.json

# Duplicate legacy-capitalized agent files (lowercase versions are canonical)
agents/Code_Reviewer.json
agents/Hacker.json

# Runtime workspace state (auto-generated, instance-specific)
workspace-index.json

# Env / secrets
.env
.env.*
*.pem
*.key

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# ── Browser session / cookie data ─────────────────────────────────────────
# Belt-and-suspenders: the embedded browser stores its persistent session in
# the OS userData directory (%APPDATA%\claude-code-desktop\Partitions\
# ccm-browser\) which is OUTSIDE this repo. These globs catch any accidental
# drop of cookie / session files into the project dir.
Cookies
Cookies-journal
cookies-*.json
cookies-export.json
**/*.sqlite
**/Local State
ccm-browser-cookies/
