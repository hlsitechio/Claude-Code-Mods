{
  "manifest_version": 3,
  "name": "CCM Companion",
  "version": "1.1.0",
  "description": "Bridges CCM (Claude Code Mods) to Chrome extension APIs that CDP cannot reach — tab groups, sessions, reading list, history, bookmarks, downloads, management, declarativeNetRequest, search, side panel, system info.",
  "permissions": [
    "tabs",
    "tabGroups",
    "sessions",
    "readingList",
    "history",
    "bookmarks",
    "downloads",
    "management",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback",
    "storage",
    "search",
    "sidePanel",
    "notifications",
    "alarms",
    "topSites",
    "system.cpu",
    "system.memory",
    "system.display",
    "system.storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "CCM Companion" }
}
